# Database (Supabase Postgres)
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres"

# Supabase
SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="<your-service-role-key>"   # Settings → API → service_role secret
SUPABASE_JWT_SECRET="<your-jwt-secret>"               # Settings → API → JWT Secret

# Auth — require a 6-digit email verification code on email signup.
# Keep false until the Supabase email OTP template uses {{ .Token }} and SMTP is set.
ENFORCE_EMAIL_VERIFICATION=false

# Server
PORT=3000

# Comma-separated extra CORS origins (production frontend domains).
# localhost:3000 and localhost:3001 are always allowed.
CORS_ORIGINS="https://your-frontend.vercel.app"
